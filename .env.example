# Copy to .env and fill in. Load before launching:  set -a; . ./.env; set +a

# ---- eval API ----
EVAL_API_URL=http://localhost:8765
EVAL_ADMIN_TOKEN=change-me            # any non-empty string; the agent uses it to POST /score
# EVAL_DATASETS_FILTER=auto_insurance,fremtpl2   # optional: serve only a subset

# ---- run identity (read by the plan's seeding) ----
RUN_INDEX=1                           # per-trial seed = 1000*RUN_INDEX + trial
WIKI_VERSION=0531

# ---- harness credentials (only the one(s) you actually use) ----
# Claude Code : `claude` CLI login (claude setup-token) or ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=
# Codex       : `codex` login or OPENAI_API_KEY
# OPENAI_API_KEY=
# Antigravity : `agy` login (agy auth)
# openclaw    : ~/.openclaw config (provider keys / gateway)
